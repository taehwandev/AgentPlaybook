  "request_intents": [
    {
      "name": "code_cleanup",
      "commands": ["code-simplify", "refactor"],
      "docs": [
        "workflows/refactor-cleanup.md",
        "common/refactoring.md",
        "common/code-structure-ownership.md",
        "common/testing.md",
        "common/verification-policy.md"
      ],
      "reason": "Cleanup and refactor requests need behavior-preserving refactor, ownership, and equivalence-check guidance."
    },
    {
      "name": "change_review",
      "commands": ["review", "docs-review"],
      "docs": [
        "workflows/review-and-commit.md",
        "common/code-review.md",
        "common/worktree-hygiene.md",
        "common/verification-policy.md"
      ],
      "reason": "Review requests need diff review, worktree hygiene, and verification evidence guidance."
    },
    {
      "name": "verification",
      "commands": ["test", "webperf"],
      "docs": [
        "common/testing.md",
        "common/scenario-driven-testing.md",
        "common/verification-policy.md",
        "common/definition-of-done.md"
      ],
      "reason": "Verification requests need test scope, scenario, evidence, and done criteria guidance."
    },
    {
      "name": "natural_language_doc_routing",
      "commands": ["workflow-setup", "task", "docs", "docs-review", "review"],
      "request_any": [
        "\\b(natural language|semantic|document routing|doc routing|doc-route|route docs|docs-read|hook|hooks?)\\b",
        "\\b(search|retrieval)\\b.*\\b(docs?|documents?|skills?)\\b",
        "(\\uc790\\uc5f0\\uc5b4|\\uc758\\ubbf8).*(\\uac80\\uc0c9|\\ubb38\\uc11c|\\ub77c\\uc6b0\\ud305)",
        "(\\ubb38\\uc11c|\\uc2a4\\ud0ac).*(\\uac80\\uc0c9|\\ub77c\\uc6b0\\ud305|\\ubd88\\ub7ec|\\uc77d)",
        "(\\ud6c5|hook).*(\\ubb38\\uc11c|\\uac80\\uc0c9|\\uc77d)"
      ],
      "docs": [
        "workflows/scripted-agent-workflow.md",
        "workflows/agent-task-lifecycle.md",
        "common/task-intake-effort-routing.md",
        "common/source-driven-development.md",
        "common/agent-skill-card-anatomy.md",
        "common/tool-failure-recovery.md"
      ],
      "reason": "Natural-language document routing work must treat hooks as enforcement points and load the routing, intake, source, skill-card, and tool-failure guidance that defines how required docs are selected and verified."
    },
    {
      "name": "android_compose_ui_feature",
      "commands": ["feature", "task", "build"],
      "platforms": ["android"],
      "request_all": [
        [
          "\\b(screen|screens|ui|layout|list|lists|favorite|favorites|navigation|tab)\\b",
          "(\\ud654\\uba74|\\ubaa9\\ub85d|\\ub9ac\\uc2a4\\ud2b8|\\uc990\\uaca8\\ucc3e\\uae30|\\ud0ed|\\ub124\\ube44|\\ub0b4\\ube44)"
        ],
        [
          "\\b(build|create|implement|compose|design|add|make)\\b",
          "(\\uad6c\\uc131|\\uad6c\\ud604|\\ub9cc\\ub4e4|\\uc791\\uc131|\\ucd94\\uac00|\\uc9dc\\uc918)"
        ]
      ],
      "doc_sets": ["android_compose_ui"],
      "reason": "Android screen, list, favorite, navigation, or tab feature work should load Compose UI, state, review, source coverage, visual verification, and Compose performance guidance before code generation."
    },
    {
