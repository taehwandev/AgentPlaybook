  "path_surfaces": [
    {
      "name": "workflow_router",
      "patterns": [
        "scripts/workflow*.py",
        "scripts/agent-preflight.py",
        "scripts/agent-hook.py",
        "scripts/agent-docs-read.py",
        "scripts/agent-finish-check.py",
        "scripts/agent_*",
        "scripts/agent-*",
        "scripts/support/*setup*.py"
      ],
      "docs": [
        "workflows/scripted-agent-workflow.md",
        "workflows/agent-task-lifecycle.md",
        "common/tool-failure-recovery.md",
        "common/ci-cd-automation.md"
      ],
      "reason": "Workflow and hook script changes affect the executable route, preflight, docs-read, and finish gates."
    },
    {
      "name": "request_classifier",
      "patterns": [
        "scripts/workflow_request.py",
        "scripts/workflow_request_patterns.py",
        "workflows/skills/request-triage/**",
        "common/skills/task-intake-effort-routing/**"
      ],
      "docs": [
        "common/task-intake-effort-routing.md",
        "workflows/request-triage.md",
        "workflows/ambiguity-gate.md"
      ],
      "reason": "Request classification changes need intake, triage, and ambiguity routing guidance."
    },
    {
      "name": "android_compose_paths",
      "patterns": [
        "app/src/main/**/ui/**/*.kt",
        "*/src/main/**/ui/**/*.kt",
        "**/src/main/**/compose/**/*.kt",
        "**/src/main/**/*Screen.kt",
        "**/src/main/**/*Route.kt",
        "**/src/main/**/*Composable.kt",
        "**/src/main/**/*UiState.kt"
      ],
      "doc_sets": ["android_compose_ui"],
      "reason": "Touched Android Kotlin UI, screen, route, composable, or UiState paths imply Android Compose UI/state and performance guidance should be read."
    },
    {
      "name": "application_desktop_paths",
      "patterns": [
        "src-tauri/**",
        "electron/**",
        "tauri.conf.json",
        "src/**/ipc/**/*.ts",
        "src/**/renderer/**/*.tsx"
      ],
      "doc_sets": ["application_ui"],
      "reason": "Touched desktop shell, command, IPC, or renderer paths imply application command/UI guidance should be read."
    },
    {
      "name": "flutter_widget_paths",
      "patterns": [
        "lib/**/screens/**/*.dart",
        "lib/**/pages/**/*.dart",
        "lib/**/widgets/**/*.dart",
        "**/*_screen.dart",
        "**/*_page.dart",
        "**/*_widget.dart"
      ],
      "doc_sets": ["flutter_ui"],
      "reason": "Touched Flutter screen, page, or widget paths imply Flutter widget UI/state guidance should be read."
    },
    {
      "name": "ios_swiftui_paths",
      "patterns": [
        "**/*View.swift",
        "**/*Screen.swift"
      ],
      "doc_sets": ["ios_swiftui"],
      "reason": "Touched SwiftUI view, screen, or view-model paths imply iOS SwiftUI/state/design guidance should be read."
    },
    {
      "name": "ios_uikit_paths",
      "patterns": [
        "**/*ViewController.swift",
        "**/*CollectionViewCell.swift",
        "**/*TableViewCell.swift",
        "**/*Coordinator.swift"
      ],
      "doc_sets": ["ios_uikit"],
      "reason": "Touched UIKit view-controller, cell, or coordinator paths imply UIKit/state/design guidance should be read."
    },
    {
      "name": "kmp_compose_paths",
      "patterns": [
        "**/commonMain/**/ui/**/*.kt",
        "**/commonMain/**/compose/**/*.kt",
        "**/commonMain/**/*Screen.kt",
        "**/commonMain/**/*Composable.kt",
        "**/commonMain/**/*UiState.kt"
      ],
      "doc_sets": ["kmp_compose_ui"],
      "reason": "Touched KMP commonMain Compose UI paths imply Compose Multiplatform state/module guidance should be read."
    },
    {
      "name": "swift_design_paths",
      "patterns": [
        "Sources/**/DesignSystem/**/*.swift",
        "Sources/**/*Style.swift",
        "Sources/**/*Modifier.swift",
        "Sources/**/*Primitive.swift",
        "Sources/**/*Component.swift"
      ],
      "doc_sets": ["swift_ui_design"],
      "reason": "Touched Swift design-system, style, modifier, primitive, or component paths imply Swift UI/design guidance should be read."
    },
    {
      "name": "web_react_paths",
      "patterns": [
        "app/**/page.tsx",
        "app/**/layout.tsx",
        "pages/**/*.tsx",
        "src/**/pages/**/*.tsx",
        "src/**/routes/**/*.tsx",
        "src/**/screens/**/*.tsx",
        "src/**/components/**/*.tsx",
        "src/**/features/**/*.tsx",
        "**/*Screen.tsx",
        "**/*Page.tsx"
      ],
      "doc_sets": ["web_ui"],
      "reason": "Touched React page, route, screen, component, or feature paths imply web UI/state/design guidance should be read."
    },
    {
      "name": "tests",
      "patterns": [
        "tests/**",
        "test/**",
        "**/*_test.py",
        "**/test_*.py"
      ],
      "docs": [
