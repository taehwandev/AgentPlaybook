    {
      "name": "playbook_docs",
      "patterns": [
        "README.md",
        "index.md",
        "workflows/README.md",
        "common/**/*.md",
        "workflows/**/*.md",
        "platforms/**/*.md",
        "product-patterns/**/*.md",
        "docs/**/*.md"
      ],
      "docs": [
